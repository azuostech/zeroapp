generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String?
  googleId      String?   @unique
  avatar        String?
  role          Role      @default(USER)
  tier          Tier      @default(DESPERTAR)
  coins         Int       @default(50)
  totalCoins    Int       @default(50)
  phase         Phase     @default(BOMBEIRO)
  showInRanking Boolean   @default(false)
  isActive      Boolean   @default(true)
  referralCode  String    @unique @default(cuid())
  referredById  String?
  referredBy    User?     @relation("UserReferrals", fields: [referredById], references: [id])
  referrals     User[]    @relation("UserReferrals")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  transactions  FinancialTransaction[]
  goals         Goal[]
  debts         Debt[]
  investments   Investment[]
  coinHistory   CoinHistory[]
  badges        UserBadge[]
  missions      UserMission[]
  refreshTokens RefreshToken[]
}

enum Role {
  USER
  ADMIN
}

enum Tier {
  DESPERTAR
  MOVIMENTO
  ACELERACAO
  AUTOGOVERNO
}

enum Phase {
  BOMBEIRO
  SOBREVIVENTE
  CONSTRUTOR
  MULTIPLICADOR
}

model FinancialTransaction {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  type        TransactionType
  description String
  category    String
  subtype     String?
  amount      Float
  date        DateTime
  month       String
  createdAt   DateTime        @default(now())
}

enum TransactionType {
  ENTRADA
  SAIDA
}

model Debt {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  creditor     String
  totalAmount  Float
  interestRate Float?
  installment  Float?
  dueDay       String?
  status       String   @default("Em dia")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Investment {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  institution   String
  type          String
  amount        Float
  date          DateTime
  profitability String?
  createdAt     DateTime @default(now())
}

model Goal {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  name          String
  targetAmount  Float
  deadline      String
  monthlyAmount Float?
  currentAmount Float    @default(0)
  completed     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CoinHistory {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  amount      Int
  reason      CoinReason
  description String?
  createdAt   DateTime   @default(now())
}

enum CoinReason {
  CADASTRO
  PRIMEIRO_LANCAMENTO_MES
  MES_COMPLETO
  META_CONCLUIDA
  DIVIDA_QUITADA
  INDICACAO
  RESGATE_MOVIMENTO
  ACELERACAO_ATIVA
  AUTOGOVERNO_ATIVO
  SEQUENCIA_3_MESES
  ADMIN_AJUSTE
  RESGATE_RECURSO
}

model Badge {
  id          String     @id @default(cuid())
  key         String     @unique
  name        String
  description String
  icon        String
  users       UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  badgeId  String
  badge    Badge    @relation(fields: [badgeId], references: [id])
  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
}

model Mission {
  id          String        @id @default(cuid())
  key         String        @unique
  name        String
  description String
  phase       Phase
  coinReward  Int
  users       UserMission[]
}

model UserMission {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  missionId   String
  mission     Mission   @relation(fields: [missionId], references: [id])
  completedAt DateTime?

  @@unique([userId, missionId])
}

model WorkshopCode {
  id        String   @id @default(cuid())
  code      String   @unique
  tier      Tier
  coinBonus Int
  usedBy    String?
  usedAt    DateTime?
  expiresAt DateTime?
  createdAt DateTime @default(now())
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}
